# Base URL gọi API backend (khớp Spring `@RequestMapping("/api/v1/...")`).
# Dev: để giá trị này là `/api/v1` để Vite proxy (vite.config.ts) forward sang http://localhost:8080
VITE_API_BASE_URL=/api/v1

# Trường hợp gọi BE trực tiếp (BE phải bật CORS allow credentials):
# VITE_API_BASE_URL=http://localhost:8080/api/v1

VITE_API_URL=http://localhost:8080/api
VITE_ADMIN_API_URL=http://localhost:8080/api/admin
VITE_STAFF_API_URL=http://localhost:8080/api/staff
